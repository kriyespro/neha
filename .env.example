# Copy this file to .env and fill in your values before running docker-compose.
# NEVER commit .env to git.

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# PostgreSQL password — use a strong random password in production
DB_PASSWORD=change-me-to-a-strong-password
